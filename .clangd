# Clangd configuration for STM32 bare-metal (works great with Neovim clangd plugin).

# Point clangd to the compile_commands.json generated by CMake in ./build
CompilationDatabase: build

CompileFlags:
  # Add MCU-specific flags and preprocessor defines so clangd "sees" the right code paths.
  Add: [
    "-mcpu=cortex-m3",
    "-mthumb",
    "-DUSE_HAL_DRIVER",
    "-DSTM32F103xB",
    # Optional: treat all warnings as info for IDE; real build still uses GCC flags
    "-Wall","-Wextra"
  ]

# Enable clang-tidy in-editor (non-blocking). Configure checks in .clang-tidy below.
Diagnostics:
  ClangTidy: true
  ClangTidyChecks: "-*,bugprone-*,clang-analyzer-*,performance-*,readability-*"
  Suppress: ["-Wunknown-attributes"]

Index:
  Background: Build   # incremental, avoids lag

# Header insertion style for C projects (no <...> guesswork).
HeaderInsertion: Never
